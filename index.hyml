<!DOCTYPE html>
<html lang="ar">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>لأجمل بنوته في الدنيا 🤭♥</title>

<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;700&display=swap" rel="stylesheet">

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:'Cairo',sans-serif;
}

body{
background:#000;
overflow-x:hidden;
color:white;
text-align:center;
min-height:100vh;
position:relative;
}

/* خلفية القلوب */

.hearts{
position:fixed;
width:100%;
height:100%;
top:0;
left:0;
pointer-events:none;
z-index:1;
overflow:hidden;
}

.heart{
position:absolute;
color:#ff2d75;
animation:fall linear infinite;
opacity:.7;
}

@keyframes fall{
0%{
transform:translateY(-10vh);
opacity:1;
}
100%{
transform:translateY(110vh);
opacity:0;
}
}

/* شاشة الباسورد */

#passwordScreen{
position:fixed;
inset:0;
background:black;
display:flex;
justify-content:center;
align-items:center;
z-index:1000;
padding:20px;
}

.pass-box{
background:#111;
padding:30px;
border-radius:25px;
width:100%;
max-width:350px;
box-shadow:0 0 30px rgba(255,0,120,.4);
}

.pass-box h1{
font-size:28px;
margin-bottom:20px;
color:#ff4f95;
}

input{
width:100%;
padding:15px;
border:none;
border-radius:15px;
outline:none;
font-size:18px;
text-align:center;
margin-top:15px;
}

button{
background:#ff4f95;
color:white;
border:none;
padding:15px 25px;
border-radius:15px;
font-size:18px;
margin-top:20px;
cursor:pointer;
transition:.3s;
}

button:hover{
transform:scale(1.05);
}

/* المحتوى */

.container{
display:none;
position:relative;
z-index:2;
padding:30px 15px 80px;
}

.main-title{
font-size:42px;
color:#ff4f95;
margin-top:30px;
text-shadow:0 0 20px rgba(255,0,120,.5);
}

.typewriter{
font-size:23px;
line-height:2;
margin-top:25px;
min-height:180px;
padding:15px;
}

.gallery{
display:grid;
grid-template-columns:1fr;
gap:20px;
margin-top:30px;
}

.gallery img{
width:100%;
border-radius:25px;
box-shadow:0 0 20px rgba(255,255,255,.1);
transition:.4s;
}

.gallery img:hover{
transform:scale(1.03);
}

.counter-box{
margin-top:40px;
background:#111;
padding:20px;
border-radius:25px;
box-shadow:0 0 20px rgba(255,0,120,.2);
}

.counter-title{
font-size:25px;
color:#ff4f95;
margin-bottom:15px;
}

#counter{
font-size:22px;
line-height:2;
}

.secret-btn{
margin-top:35px;
}

.secret-message{
display:none;
margin-top:25px;
font-size:24px;
line-height:2;
animation:fade 1s ease;
background:#111;
padding:20px;
border-radius:20px;
}

@keyframes fade{
from{
opacity:0;
transform:translateY(20px);
}
to{
opacity:1;
transform:translateY(0);
}
}

.music{
margin-top:35px;
}

iframe{
border-radius:20px;
width:100%;
height:152px;
border:none;
}

/* نجوم */

.stars{
position:fixed;
inset:0;
z-index:0;
overflow:hidden;
}

.star{
position:absolute;
width:2px;
height:2px;
background:white;
border-radius:50%;
animation:blink 2s infinite;
}

@keyframes blink{
50%{
opacity:.3;
}
}

</style>
</head>

<body>

<div class="stars"></div>
<div class="hearts"></div>

<!-- شاشة الباسورد -->

<div id="passwordScreen">

<div class="pass-box">

<h1>ادخلي الباسورد 🤭♥</h1>

<input type="password" id="password" placeholder="اكتبيه هنا">

<button onclick="checkPassword()">
فتح المفاجأة ♥
</button>

</div>

</div>

<!-- المحتوى -->

<div class="container" id="mainContent">

<h1 class="main-title">
لأجمل بنوته في الدنيا 🤭♥
</h1>

<div class="typewriter" id="typewriter"></div>

<div class="gallery">

<img src="https://i.imgur.com/0Q2Qw6D.jpeg">

<img src="https://i.imgur.com/eQ0Qm7R.jpeg">

<img src="https://i.imgur.com/Jl7vP8R.jpeg">

<img src="https://i.imgur.com/H2uRjM8.jpeg">

</div>

<div class="counter-box">

<div class="counter-title">
بقالنا مع بعض ♥
</div>

<div id="counter"></div>

</div>

<div class="secret-btn">

<button onclick="showSecret()">
اضغطي هنا عشان تشوفي حاجة مهمة 🥺♥
</button>

<div class="secret-message" id="secretMessage">

أنا فعلًا بحبك جدًا ♥<br>
ونفسي أشوفك كده على الحقيقة 🫂<br>
ونفسي تبقي من نصيبي ونفضل مع بعض علطول ♥<br><br>

ومتزعليش مني بو بتعصب وبزعلك ساعات 😂♥

</div>

</div>

<div class="music">

<iframe src="https://open.spotify.com/embed/track/0AVdTy2X1vIzRP6wjBuzso?utm_source=generator"
allowfullscreen
allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture">
</iframe>

</div>

</div>

<script>

/* الباسورد */

function checkPassword(){

let pass=document.getElementById("password").value;

if(pass==="19/3/2025"){

document.getElementById("passwordScreen").style.display="none";

document.getElementById("mainContent").style.display="block";

startTyping();

}else{

alert("الباسورد غلط 🥺");
}
}

/* الكتابة */

const text=
`بحبك اوي ونفسي اشوفك كده علي الحقيقه ونفسي تبقي من نصيبي ونفضل مع بعض علطول 🫂♥

ومتزعليش مني بو بتعصب وبزعلك سعات 😂♥

وكل سنة وانتي طيبة يا أحلى عيد ميلاد في الدنيا 🎂♥`;

let i=0;

function startTyping(){

const speed=55;

function typing(){

if(i<text.length){

document.getElementById("typewriter").innerHTML+=text.charAt(i);

i++;

setTimeout(typing,speed);

}
}

typing();
}

/* الرسالة السرية */

function showSecret(){

document.getElementById("secretMessage").style.display="block";
}

/* العداد */

const startDate = new Date("2025-03-19T18:27:00");

function updateCounter(){

const now = new Date();

const diff = now - startDate;

const days = Math.floor(diff / (1000*60*60*24));

const hours = Math.floor((diff / (1000*60*60)) % 24);

const minutes = Math.floor((diff / (1000*60)) % 60);

const seconds = Math.floor((diff / 1000) % 60);

document.getElementById("counter").innerHTML=
`${days} يوم <br>
${hours} ساعة <br>
${minutes} دقيقة <br>
${seconds} ثانية`;
}

setInterval(updateCounter,1000);

/* القلوب */

const heartsContainer=document.querySelector('.hearts');

for(let i=0;i<60;i++){

let heart=document.createElement('div');

heart.classList.add('heart');

heart.innerHTML='♥';

heart.style.left=Math.random()*100+'%';

heart.style.fontSize=(15+Math.random()*35)+'px';

heart.style.animationDuration=
(4+Math.random()*6)+'s';

heartsContainer.appendChild(heart);
}

/* النجوم */

const stars=document.querySelector('.stars');

for(let i=0;i<120;i++){

let star=document.createElement('div');

star.classList.add('star');

star.style.left=Math.random()*100+'%';

star.style.top=Math.random()*100+'%';

star.style.animationDuration=
(1+Math.random()*3)+'s';

stars.appendChild(star);
}

</script>

</body>
</html>
